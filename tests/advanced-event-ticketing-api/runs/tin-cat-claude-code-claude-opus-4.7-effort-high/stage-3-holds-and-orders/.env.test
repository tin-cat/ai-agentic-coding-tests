KERNEL_CLASS='Frontstage\Kernel'
APP_SECRET='$ecretf0rt3st'
SYMFONY_DEPRECATIONS_HELPER=999999

# Tests run against a dedicated Postgres database (`app_test`) provisioned by
# docker/postgres/init-test-db.sh on first container start. The hostname
# `database` resolves on the docker compose network.
DATABASE_URL="postgresql://app:app@database:5432/app_test?serverVersion=16&charset=utf8"
