<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="Frontstage\Catalog\Infrastructure\Persistence\Doctrine\Entity\DoctrinePriceTier"
            table="catalog_price_tiers">

        <unique-constraints>
            <unique-constraint name="uniq_catalog_price_tier_event_tier" columns="event_id,tier_id"/>
        </unique-constraints>

        <id name="id" type="integer">
            <generator strategy="IDENTITY"/>
        </id>

        <field name="tierId" type="string" column="tier_id" length="63" nullable="false"/>
        <field name="name" type="string" length="100" nullable="false"/>
        <field name="priceAmount" type="integer" column="price_amount" nullable="false"/>
        <field name="priceCurrency" type="string" column="price_currency" length="3" nullable="false"/>

        <many-to-one field="event"
                     target-entity="Frontstage\Catalog\Infrastructure\Persistence\Doctrine\Entity\DoctrineEvent"
                     inversed-by="priceTiers">
            <join-column name="event_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>

    </entity>
</doctrine-mapping>
