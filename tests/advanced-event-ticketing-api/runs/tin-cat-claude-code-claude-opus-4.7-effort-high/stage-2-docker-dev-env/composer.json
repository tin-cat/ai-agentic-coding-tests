{
	"name": "frontstage/backend",
	"description": "Frontstage event ticketing platform backend (API-only).",
	"type": "project",
	"license": "proprietary",
	"require": {
		"php": ">=8.2",
		"ext-ctype": "*",
		"ext-iconv": "*",
		"doctrine/dbal": "^3.8",
		"doctrine/doctrine-bundle": "^2.12",
		"doctrine/doctrine-migrations-bundle": "^3.3",
		"doctrine/orm": "^2.19",
		"symfony/amqp-messenger": "^6.4",
		"symfony/cache": "^6.4",
		"symfony/console": "^6.4",
		"symfony/dotenv": "^6.4",
		"symfony/flex": "^2",
		"symfony/framework-bundle": "^6.4",
		"symfony/lock": "^6.4",
		"symfony/messenger": "^6.4",
		"symfony/runtime": "^6.4",
		"symfony/uid": "^6.4",
		"symfony/yaml": "^6.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5",
		"symfony/browser-kit": "^6.4",
		"symfony/phpunit-bridge": "^6.4"
	},
	"config": {
		"allow-plugins": {
			"symfony/flex": true,
			"symfony/runtime": true
		},
		"sort-packages": true
	},
	"autoload": {
		"psr-4": {
			"Frontstage\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Frontstage\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": [
			"@php -d memory_limit=512M vendor/bin/phpunit"
		],
		"auto-scripts": {
			"cache:clear": "symfony-cmd",
			"assets:install %PUBLIC_DIR%": "symfony-cmd"
		}
	},
	"extra": {
		"symfony": {
			"allow-contrib": false,
			"require": "6.4.*"
		}
	}
}
