<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="Frontstage\Catalog\Infrastructure\Persistence\Doctrine\Entity\DoctrineSeat"
            table="catalog_seats">

        <indexes>
            <index name="idx_catalog_seat_event" columns="event_id"/>
        </indexes>

        <unique-constraints>
            <unique-constraint name="uniq_catalog_seat_event_loc"
                               columns="event_id,section,row_label,seat_number"/>
        </unique-constraints>

        <id name="id" type="bigint">
            <generator strategy="IDENTITY"/>
        </id>

        <field name="section" type="string" length="64" nullable="false"/>
        <field name="rowLabel" type="string" column="row_label" length="64" nullable="false"/>
        <field name="seatNumber" type="string" column="seat_number" length="32" nullable="false"/>
        <field name="priceTierId" type="string" column="price_tier_id" length="63" nullable="false"/>
        <field name="status" type="string" length="20" nullable="false"/>

        <many-to-one field="event"
                     target-entity="Frontstage\Catalog\Infrastructure\Persistence\Doctrine\Entity\DoctrineEvent"
                     inversed-by="seats">
            <join-column name="event_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>

    </entity>
</doctrine-mapping>
